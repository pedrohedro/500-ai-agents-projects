# ===========================================================================
# Monetization Platform — environment configuration
# Copy to `.env` and fill in. EVERYTHING has a safe default: with no .env at all
# the platform runs in full mock mode (mock Stripe + mock LLM) on SQLite.
# ===========================================================================

# --- Core -------------------------------------------------------------------
APP_NAME="Agent API Cloud"
# Public base URL (used for Stripe redirect + mock checkout links).
BASE_URL="http://localhost:8000"
# SQLite by default. For Postgres: postgresql+psycopg://user:pass@host:5432/db
DATABASE_URL="sqlite:///./monetization.db"

# --- LLM provider (pass-through to the wrapped agents) ----------------------
# One of: mock | openai | openrouter
LLM_PROVIDER="mock"
LLM_MODEL="gpt-4o-mini"
# Set this to go live on OpenRouter (recommended for production):
OPENROUTER_API_KEY=""
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
# Or use OpenAI directly:
OPENAI_API_KEY=""

# --- Stripe (leave STRIPE_API_KEY blank to use MOCK Stripe mode) ------------
STRIPE_API_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_SUCCESS_URL="http://localhost:8000/dashboard?checkout=success"
STRIPE_CANCEL_URL="http://localhost:8000/?checkout=cancelled"
STRIPE_CURRENCY="usd"

# --- Pricing / economics ----------------------------------------------------
# Free credits granted on signup.
SIGNUP_BONUS_CREDITS=25
# Retail price of one credit (for margin docs / analytics).
CREDIT_PRICE_USD=0.02

# Per-agent credit cost per successful call.
COST_MARKETING=5
COST_LEGAL=8
COST_SUPPORT=1
COST_HR=3

# Credit packs (price in USD + credits granted).
PACK_STARTER_PRICE=19
PACK_STARTER_CREDITS=1000
PACK_PRO_PRICE=79
PACK_PRO_CREDITS=5000
PACK_BUSINESS_PRICE=299
PACK_BUSINESS_CREDITS=25000
