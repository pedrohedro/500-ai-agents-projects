# ---------------------------------------------------------------------------
# HR Resume Screening Agent - example environment
# Copy to `.env` and edit. The default (mock) needs NO changes and NO keys.
# ---------------------------------------------------------------------------

# LLM provider: "mock" (default, offline), "openrouter" (open-source) or "openai"
LLM_PROVIDER=mock

# --- OpenRouter (open-source models; RECOMMENDED for production) ------------
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Best open-source models for resume screening (structured reasoning):
#   deepseek/deepseek-v4-flash -> cheapest, fast, 1M context [DEFAULT]
#   qwen/qwen-3-235b           -> strong multilingual resumes
#   meta-llama/llama-4-maverick -> best general/multilingual (incl. PT-BR)
OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# Only required when LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Billing / pricing -----------------------------------------------------
# Your blended API cost per 1k tokens (used to derive customer price).
PRICE_PER_1K_TOKENS_USD=0.01
# Markup applied over API cost for the token pricing strategy.
MARGIN_MULTIPLIER=3.0
# Flat per-resume price (used when PRICING_STRATEGY=flat).
PRICE_PER_RESUME_USD=0.50
# Pricing strategy: "token" (cost x margin) or "flat" (per resume).
PRICING_STRATEGY=token

# --- Stripe (optional) -----------------------------------------------------
# Leave blank to keep checkout cleanly disabled (stub responses).
STRIPE_API_KEY=

# --- QA gate ---------------------------------------------------------------
# Matches below this confidence are flagged for human review.
MIN_CONFIDENCE=0.35
