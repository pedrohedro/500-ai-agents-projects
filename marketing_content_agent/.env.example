# ---------------------------------------------------------------------------
# Marketing Content Agent — environment configuration
# Copy to .env and edit. ALL values have defaults; the app runs with none set.
# ---------------------------------------------------------------------------

# --- LLM provider ---------------------------------------------------------
# "mock"      -> deterministic, offline, no API key required (DEFAULT, used for CI)
# "openrouter"-> open-source models via OpenRouter (RECOMMENDED for production)
# "openai"    -> calls the OpenAI API (requires OPENAI_API_KEY)
LLM_PROVIDER=mock

# --- OpenRouter (open-source models) -------------------------------------
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Best open-source models for marketing copy (uncomment your pick):
#   meta-llama/llama-4-maverick   -> best general/multilingual (great for PT-BR) [DEFAULT]
#   qwen/qwen-3-235b              -> strong multilingual + creative
#   deepseek/deepseek-v4-flash    -> cheapest, fast, 1M context
#   z-ai/glm-4.7                  -> strong instruction following
# Append ":free" to a model id to use OpenRouter's free tier while testing.
OPENROUTER_MODEL=meta-llama/llama-4-maverick

# Required only when LLM_PROVIDER=openai
OPENAI_API_KEY=

# Model + sampling (LLM_MODEL used by the openai provider; also selects price row)
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.7

# --- Billing / credits ----------------------------------------------------
# Credits a new wallet starts with (used by demos/CLI --credits default flows)
STARTING_CREDITS=100
# Credits deducted per content generation
CREDITS_PER_GENERATION=5
# Retail price charged to the customer per credit (USD)
CREDIT_PRICE_USD=0.20
# Target markup over raw API cost (documentation/analytics)
MARKUP_MULTIPLIER=5.0

# --- Stripe (checkout stub) ----------------------------------------------
# Leave STRIPE_API_KEY empty to keep checkout cleanly DISABLED.
STRIPE_API_KEY=
STRIPE_PRICE_ID=

# --- Scheduler ------------------------------------------------------------
# Interval for the cron-style autonomous loop (seconds)
SCHEDULE_INTERVAL_SECONDS=3600
