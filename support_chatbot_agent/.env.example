# ---------------------------------------------------------------------------
# 24/7 Support Chatbot -- environment configuration
# Copy to `.env` and adjust. The defaults run fully offline in MOCK mode.
# ---------------------------------------------------------------------------

# Provider: "mock" (offline), "openrouter" (open-source, recommended) or "openai".
LLM_PROVIDER=mock

# --- OpenRouter (open-source models; RECOMMENDED for production) -----------
# Get a key at https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Best open-source chat models for 24/7 support (fast + cheap wins here):
#   deepseek/deepseek-v4-flash -> cheapest, fast, high throughput [DEFAULT]
#   meta-llama/llama-4-maverick -> best multilingual (incl. PT-BR)
#   qwen/qwen-3-235b           -> strong multilingual
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
# Embeddings for openrouter mode: "local" (offline hashed, no cost) or "openai".
EMBEDDING_BACKEND=local

# --- OpenAI (only used when LLM_PROVIDER=openai, or EMBEDDING_BACKEND=openai) --
# OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Retrieval / RAG tuning -----------------------------------------------
# KNOWLEDGE_BASE_DIR=knowledge_base
# INDEX_PATH=data/index.json
CHUNK_SIZE=250
CHUNK_OVERLAP=40
TOP_K=4
EMBEDDING_DIM=768

# Escalate to a human when the best retrieval similarity is below this.
CONFIDENCE_THRESHOLD=0.18

# --- Billing / monetization -----------------------------------------------
PRICE_PER_1K_TOKENS=0.02
API_COST_PER_1K_TOKENS=0.005
FREE_CREDITS=1.0

# --- Stripe (checkout stub is disabled unless STRIPE_API_KEY is set) -------
# STRIPE_API_KEY=sk_test_...
# STRIPE_PRICE_ID=price_...
