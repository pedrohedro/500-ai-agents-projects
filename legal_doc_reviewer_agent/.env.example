# ---------------------------------------------------------------------------
# Legal Document Reviewer - example environment
# Copy to `.env` and adjust. The product runs with NONE of these set (mock mode).
# ---------------------------------------------------------------------------

# LLM provider: "mock" (default, no keys, fully offline) or "openai".
LLM_PROVIDER=mock

# Required only when LLM_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Pricing / billing -----------------------------------------------------
# Customer-facing price per 1k tokens (variable component).
PRICE_PER_1K_TOKENS=0.03
# Our estimated underlying API cost per 1k tokens (used to compute margin).
API_COST_PER_1K_TOKENS=0.005
# Flat fee added to every document review.
FLAT_FEE_PER_DOCUMENT=0.50
# Where the file-backed credit balance is stored.
CREDITS_FILE=.credits.json

# --- Stripe (checkout stub; disabled unless STRIPE_API_KEY is set) ----------
STRIPE_API_KEY=
STRIPE_PRICE_ID=

# --- Automation ------------------------------------------------------------
INBOX_DIR=inbox
OUTBOX_DIR=outbox
POLL_INTERVAL_SECONDS=10

# --- QA gate ---------------------------------------------------------------
# Findings below this confidence are flagged for human review.
QA_CONFIDENCE_THRESHOLD=0.6
