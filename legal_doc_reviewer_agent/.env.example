# ---------------------------------------------------------------------------
# Legal Document Reviewer - example environment
# Copy to `.env` and adjust. The product runs with NONE of these set (mock mode).
# ---------------------------------------------------------------------------

# LLM provider: "mock" (default, offline), "openrouter" (open-source) or "openai".
LLM_PROVIDER=mock

# --- OpenRouter (open-source models; RECOMMENDED for production) ------------
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Best open-source models for contract analysis (need JSON/structured output):
#   deepseek/deepseek-v4-flash -> cheapest, 1M context, strong JSON [DEFAULT]
#   deepseek/deepseek-r2       -> best reasoning for tricky risk analysis
#   qwen/qwen-3-235b           -> strong multilingual contracts
OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# Required only when LLM_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Pricing / billing -----------------------------------------------------
# Customer-facing price per 1k tokens (variable component).
PRICE_PER_1K_TOKENS=0.03
# Our estimated underlying API cost per 1k tokens (used to compute margin).
# Open-source models via OpenRouter cost ~$0.0001-0.0005/1k (much lower).
API_COST_PER_1K_TOKENS=0.005
# Flat fee added to every document review.
FLAT_FEE_PER_DOCUMENT=0.50
# Where the file-backed credit balance is stored.
CREDITS_FILE=.credits.json

# --- Stripe (checkout stub; disabled unless STRIPE_API_KEY is set) ----------
STRIPE_API_KEY=
STRIPE_PRICE_ID=

# --- Automation ------------------------------------------------------------
INBOX_DIR=inbox
OUTBOX_DIR=outbox
POLL_INTERVAL_SECONDS=10

# --- QA gate ---------------------------------------------------------------
# Findings below this confidence are flagged for human review.
QA_CONFIDENCE_THRESHOLD=0.6
